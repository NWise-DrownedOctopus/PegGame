import {
    Button,
    VerticalBox,
    HorizontalBox,
    CheckBox,
} from "std-widgets.slint";

export struct CellData {
    x_pos: int,
    y_pos: int,
    has_peg: bool,
}

export component AppWindow inherits Window {
    in-out property <string> hovered_cell: "";
    in-out property <string> selected_cell: "";
    in-out property <[CellData]> cells;

    callback peg_cell_clicked(x_pos: int, y_pos: int);
    callback peg_cell_hovered(x_pos: int, y_pos: int);
    callback new_game_clicked();

    VerticalBox {
        Text {
            text: "Hovered: \{root.hovered_cell}";
        }

        Text {
            text: "Selected Start: \{root.selected_cell}";
        }

        Rectangle {
            width: 400px;
            height: 400px;

            for cell in root.cells: Rectangle {
                // Each cell is positioned absolutely within the 400x400 box.
                // The board is 7 cols x 7 rows, so each cell is ~57x57px.
                x: cell.x_pos * (400px / 7);
                y: cell.y_pos * (400px / 7);
                width: 400px / 7;
                height: 400px / 7;
                border-width: 2px;
                border-color: white;

                background: touch.has-hover ? #555 : #333;

                touch := TouchArea {
                    clicked => {
                        root.peg_cell_clicked(cell.x_pos, cell.y_pos);
                        root.selected_cell = "(\{cell.x_pos}, \{cell.y_pos})";
                    }
                    pointer-event(event) => {
                        if self.has-hover {
                            root.peg_cell_hovered(cell.x_pos, cell.y_pos);
                            root.hovered_cell = "(\{cell.x_pos}, \{cell.y_pos})";
                        }
                    }
                }

                // Peg circle
                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: self.width / 2;
                    background: red;
                    visible: cell.has_peg;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                }
            }
        }

        Button {
            text: "New Game";
            clicked => {
                root.new_game_clicked();
            }
        }
    }
}