import { Button, VerticalBox, HorizontalBox, CheckBox } from "std-widgets.slint";

export component PegCell inherits Rectangle {
    in property <string> name;
    in-out property <string> hovered_cell;
    in-out property <string> selected_cell;

    in property <bool> has_peg;

    callback clicked(name: string);

    background: area.has-hover ? #555 : #333;

    area := TouchArea {
        clicked => {
            root.clicked(root.name);
        }
    }

    // Draw the peg as a circle if has_peg is true
    Rectangle {
        width: 10px;
        height: 10px;
        border-radius: self.width / 2;
        background: red;
        visible: root.has_peg;
        x: parent.width / 2 - self.width / 2;
        y: parent.height / 2 - self.height / 2;
    }
}

